				phandle = <0x10a>;
				dmas = <0xc0 0x19 0xc0 0x18>;
			};

			i2c@320a0000 {
				pinctrl-names = "default";
				#address-cells = <0x01>;
				i2c-sda-hold-time-ns = <0x1e>;
				pinctrl-0 = <0xba>;
				clock-names = "i2c_clk\0pclk";
				resets = <0xb9 0x08>;
				interrupts = <0x00 0x8d 0x04>;
				clocks = <0x5b 0x21 0x5b 0x21>;
				#size-cells = <0x00>;
				interrupt-parent = <0x1c>;
				clock-frequency = <0x186a0>;
				compatible = "snps,designware-i2c";
				status = "okay";
				reg = <0x320a0000 0x10000>;
				phandle = <0x1fb>;

				es8326@18 {
					interrupts = <0x15 0x00>;
					mclk = <0x1770000>;
					interrupt-parent = <0xbd>;
					#sound-dai-cells = <0x00>;
					everest,interrupt-src = [08];
					compatible = "everest,es8326";
					status = "okay";
					reg = <0x18>;
					phandle = <0x10c>;
					everest,interrupt-clk = [00];
				};

				hdmi_bridge@3b {
					pinctrl-names = "default";
					pinctrl-0 = <0xbb 0xbc>;
					interrupts = <0x13 0x02>;
					interrupt-parent = <0xbd>;
					reset-gpios = <0xbd 0x14 0x01>;
