					status = "okay";
					reg = <0x3b>;

					ports {
						#address-cells = <0x01>;
						#size-cells = <0x00>;

						port@0 {
							reg = <0x00>;

							endpoint {
								remote-endpoint = <0xbe>;
								phandle = <0x80>;
							};
						};
					};
				};
			};

			audio-externel-clk {
				clock-output-names = "audio_externel";
				#clock-cells = <0x00>;
				clock-frequency = <0x16e3600>;
				compatible = "external-io-clock";
				phandle = <0x5a>;
