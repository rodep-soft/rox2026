	pconf-dev-pd-ds2-1v8 {
		drive-strength = <0x02>;
		bias-pull-down;
		phandle = <0xce>;
		power-source = <0x01>;
	};

	pconf-sd-sdio-pu-ds12-ipctrl {
		drive-strength = <0x0c>;
		phandle = <0x295>;
		bias-pull-up;
		power-source = <0x02>;
	};

	cpu-opp-table-0 {
		opp-shared;
		compatible = "operating-points-v2";
		status = "okay";
		phandle = <0x0f>;

		opp0 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x11e1a300>;
			clock-latency-ns = <0x9c40>;
		};

		opp3 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x59682f00>;
			opp-suspend;
			clock-latency-ns = <0x9c40>;
		};

		opp1 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x23c34600>;
			clock-latency-ns = <0x9c40>;
		};

		opp4 {
			opp-microvolt = <0xf4240 0xf4240 0xf4240>;
			turbo-mode;
			opp-hz = <0x00 0x6b49d200>;
			clock-latency-ns = <0x9c40>;
		};

		opp2 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x47868c00>;
			clock-latency-ns = <0x9c40>;
		};
	};

	bpu-opp-table {
		opp-shared;
		compatible = "operating-points-v2";
		phandle = <0x68>;

		opp0 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0x3b9aca00>;
			clock-latency-ns = <0x7a120>;
		};

		opp1 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0x1dcd6500>;
			clock-latency-ns = <0xc350>;
		};
	};

