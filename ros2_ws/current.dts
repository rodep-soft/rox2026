	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		ion_cma_rdk@CC100000 {
			alignment = <0x00 0x2000>;
			compatible = "ion-cma";
			size = <0x00 0x8000000>;
			status = "okay";
			reg = <0x00 0xcc100000 0x00 0x8000000>;
			phandle = <0x288>;
			reusable;
		};

		ion_cma_ge4g@124100000 {
			alignment = <0x00 0x2000>;
			compatible = "ion-cma";
			status = "disabled";
			reg = <0x01 0x24100000 0x00 0x20000000>;
			phandle = <0x285>;
			reusable;
		};

		ion_carveout_1g@AB100000 {
			compatible = "ion-carveout";
			status = "disabled";
			reg = <0x00 0xab100000 0x00 0x7000000>;
			phandle = <0x27e>;
		};

		ion_carveout_ge4g@E4100000 {
			compatible = "ion-carveout";
			status = "disabled";
			reg = <0x00 0xe4100000 0x00 0x40000000>;
			phandle = <0x284>;
		};

		ion_carveout_rdk@B8100000 {
			compatible = "ion-carveout";
			size = <0x00 0x14000000>;
			status = "okay";
			reg = <0x00 0xb8100000 0x00 0x14000000>;
			phandle = <0x287>;
		};

		ion_reserved_ge4g@A4100000 {
			compatible = "ion-pool";
			status = "disabled";
			reg = <0x00 0xa4100000 0x00 0x40000000>;
			phandle = <0x283>;
		};

		ion_reserved_1g@A4100000 {
			compatible = "ion-pool";
			status = "disabled";
			reg = <0x00 0xa4100000 0x00 0x7000000>;
			phandle = <0x27d>;
		};

		firewall_ddr_default@9FE7F000 {
			reg = <0x00 0x9fe7f000 0x00 0x1000>;
			phandle = <0x21>;
			no-map;
		};

		adsp_ddr@9FE80000 {
			reg = <0x00 0x9fe80000 0x00 0x2200000>;
			phandle = <0xd4>;
			no-map;
		};

		ion_cma_1g@B2100000 {
			alignment = <0x00 0x2000>;
			compatible = "ion-cma";
			status = "disabled";
			reg = <0x00 0xb2100000 0x00 0x400000>;
			phandle = <0x27f>;
			reusable;
		};

		ramoops@A4080000 {
			ecc-size = <0x00>;
			sched-size = <0x8000>;
			record-size = <0x4000>;
			pmg-size = <0x8000>;
			compatible = "ramoops";
			console-size = <0x8000>;
			reg = <0x00 0xa4080000 0x00 0x40000>;
			ftrace-size = <0x8000>;
		};

		ion_cma_2g@E4100000 {
			alignment = <0x00 0x2000>;
			compatible = "ion-cma";
			status = "disabled";
			reg = <0x00 0xe4100000 0x00 0xc000000>;
			phandle = <0x282>;
			reusable;
		};

		log@87FFC000 {
			compatible = "uboot_log";
			status = "okay";
			reg = <0x00 0x87ffc000 0x00 0x4000>;
			phandle = <0x27c>;
		};

		ion_reserved_rdk@A4100000 {
			compatible = "ion-pool";
			size = <0x00 0x14000000>;
			status = "okay";
			reg = <0x00 0xa4100000 0x00 0x14000000>;
			phandle = <0x286>;
		};

		ion_carveout_2g@C4100000 {
			compatible = "ion-carveout";
			status = "disabled";
			reg = <0x00 0xc4100000 0x00 0x20000000>;
			phandle = <0x281>;
		};

		ion_reserved_2g@A4100000 {
			compatible = "ion-pool";
			status = "disabled";
			reg = <0x00 0xa4100000 0x00 0x20000000>;
			phandle = <0x280>;
		};

		linux,cma@88000000 {
			linux,cma-default;
			compatible = "shared-dma-pool";
			reg = <0x00 0x88000000 0x00 0x17e00000>;
			phandle = <0x2d>;
			reusable;
		};
	};

	pconf-bias-disabled-ds7-1v8 {
		drive-strength = <0x07>;
		bias-disable;
		phandle = <0x28a>;
		power-source = <0x01>;
	};

	pconf-dev-od {
		drive-open-drain;
		drive-strength = <0x03>;
		phandle = <0x293>;
	};

	ipc_hal {
		compatible = "hobot,hobot-ipc-hal";
		status = "okay";
		ipc-hal = <0x10d>;
		phandle = <0x27b>;
	};

	__overrides__ {
		spi2 = [00 00 01 14 73 74 61 74 75 73 00];
		i2c1 = [00 00 01 16 73 74 61 74 75 73 00];
		uart6 = [00 00 01 11 73 74 61 74 75 73 00];
		pwm3 = [00 00 01 1a 73 74 61 74 75 73 00];
		uart2 = [00 00 01 0f 73 74 61 74 75 73 00];
		pwm1 = [00 00 01 18 73 74 61 74 75 73 00];
		uart7 = [00 00 01 12 73 74 61 74 75 73 00];
		spi1 = [00 00 01 13 73 74 61 74 75 73 00];
		i2c0 = [00 00 01 15 73 74 61 74 75 73 00];
		uart3 = [00 00 01 10 73 74 61 74 75 73 00];
		dw_i2s1 = [00 00 01 0a 73 74 61 74 75 73 00];
		pwm2 = [00 00 01 19 73 74 61 74 75 73 00];
		uart1 = [00 00 01 0e 73 74 61 74 75 73 00];
		i2c5 = [00 00 01 17 73 74 61 74 75 73 00];
		pwm0 = "\0\0\0istatus";
	};

	pconf-dev-pu-ds2-3v3 {
		drive-strength = <0x02>;
		phandle = <0xd0>;
		bias-pull-up;
		power-source = <0x00>;
	};

	pconf-dev-pd-ds7-1v8 {
		drive-strength = <0x07>;
		bias-pull-down;
		phandle = <0x28b>;
		power-source = <0x01>;
	};

	pconf-input-en-1v8-bias-disable {
		drive-strength = <0x03>;
		bias-disable;
		phandle = <0xd2>;
		power-source = <0x01>;
		input-enable;
	};
};
