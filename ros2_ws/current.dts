/dts-v1/;

/ {
	#address-cells = <0x02>;
	model = "D-Robotics RDK X5 V1.0";
	serial-number = "308118a90a2c480d029da4b80000024";
	#size-cells = <0x02>;
	compatible = "D-Robotics, x5";

	pconf-bias-disabled-ds3-3v3 {
		drive-strength = <0x03>;
		bias-disable;
		phandle = <0x29d>;
		power-source = <0x00>;
	};

	optee {
		method = "smc";
		compatible = "linaro,optee-tz";
		status = "okay";
		phandle = <0x12f>;
	};

	pconf-bias-disabled-ds7-3v3 {
		drive-strength = <0x07>;
		bias-disable;
		phandle = <0xaa>;
		power-source = <0x00>;
	};

	cpu-opp-table-3 {
		opp-shared;
		compatible = "operating-points-v2";
		status = "disabled";
		phandle = <0x122>;

		opp0 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x11e1a300>;
			clock-latency-ns = <0x9c40>;
		};

		opp3 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x59682f00>;
			opp-suspend;
			clock-latency-ns = <0x9c40>;
		};

		opp1 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x23c34600>;
			clock-latency-ns = <0x9c40>;
		};

		opp2 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x47868c00>;
			clock-latency-ns = <0x9c40>;
		};
	};

	hobot_pps {
		false_trigger_detect;
		compatible = "hobot-pps";
		status = "okay";
		phandle = <0x279>;
	};

	pconf-dev-pu-ds15 {
		drive-strength = <0x0f>;
		phandle = <0x28e>;
		bias-pull-up;
	};

	dsu-pmu {
		interrupts = <0x00 0x6e 0x04>;
		interrupt-parent = <0x1c>;
		compatible = "arm,dsu-pmu";
		status = "okay";
		phandle = <0x12d>;
		cpus = <0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a>;
	};

	pconf-input-en-1v8 {
		drive-strength = <0x03>;
		phandle = <0x63>;
		power-source = <0x01>;
		input-enable;
	};

	snd0 {
		simple-audio-card,name = "duplex-audio";
		#address-cells = <0x01>;
		#size-cells = <0x00>;
		compatible = "hobot-snd0";
		status = "okay";
		phandle = <0x278>;

		simple-audio-card,dai-link@0 {
			mclk-fs = <0x40>;
			format = "i2s";
			frame-master = <0x10b>;
			bitclock-master = <0x10b>;
			reg = <0x01>;
			link-name = "dai-link0";

			cpu {
				phandle = <0x10b>;
				sound-dai = <0x107 0x00>;
			};

			codec {
				sound-dai = <0x10c>;
			};
		};
	};

	pconf-dev-pu-ds7-1v8 {
		drive-strength = <0x07>;
		phandle = <0xfa>;
		bias-pull-up;
		power-source = <0x01>;
	};

	gpu-opp-table {
		opp-shared;
		compatible = "operating-points-v2";
		phandle = <0x64>;

		opp0 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0xbebc200>;
		};

		opp3 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0x3b9aca00>;
		};

		opp1 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0x17d78400>;
		};

		opp2 {
			opp-microvolt = "\0\f5";
			opp-hz = <0x00 0x2cb41780>;
		};
	};

	pconf-output-low {
		drive-strength = <0x03>;
		phandle = <0xb0>;
		output-low;
	};

	cpu-opp-table-1 {
		opp-shared;
		compatible = "operating-points-v2";
		status = "disabled";
		phandle = <0x120>;

		opp0 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x11e1a300>;
			clock-latency-ns = <0x9c40>;
		};

		opp3 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x59682f00>;
			opp-suspend;
			clock-latency-ns = <0x9c40>;
		};

		opp1 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x23c34600>;
			clock-latency-ns = <0x9c40>;
		};

		opp2 {
			opp-microvolt = <0xcf850 0xcf850 0xcf850>;
			opp-hz = <0x00 0x47868c00>;
			clock-latency-ns = <0x9c40>;
		};
	};

	sound-machine {
		model = "gua-audio";
		compatible = "gua,sound-card";
		cpu-dai = <0x11d>;
		status = "okay";
	};

	pconf-output-high {
		drive-strength = <0x03>;
		output-high;
		phandle = <0xd1>;
	};

	pconf-input-en-3v3 {
		drive-strength = <0x03>;
		phandle = <0xaf>;
		power-source = <0x00>;
		input-enable;
	};

	pconf-dev-pu-ds7-3v3 {
		drive-strength = <0x07>;
		phandle = <0x28c>;
		bias-pull-up;
		power-source = <0x00>;
	};

	hobot_sound_machine {
		compatible = "hobot-sound-machine";
		status = "disabled";
		phandle = <0x277>;
	};

	audio-rpc-wrapper {
		compatible = "gua,audio-rpc-wrapper";
		status = "okay";
		phandle = <0x29b>;
		rpmsg-enable;
	};

	pconf-bias-disabled-ds8-3v3 {
		drive-strength = <0x08>;
		bias-disable;
		phandle = <0xa7>;
		power-source = <0x00>;
	};

	pconf-pwm-1v8 {
		drive-strength = <0x01>;
		phandle = <0xfc>;
		power-source = <0x01>;
	};

	pconf-dev-pd {
		drive-strength = <0x03>;
		bias-pull-down;
		phandle = <0x291>;
	};

	thermal-zones {

		thermal-ddr {
			polling-delay = <0x3e8>;
			polling-delay-passive = <0x3e8>;
			thermal-sensors = <0x01 0x00>;
			phandle = <0x129>;

			trips {

				ddr-alert0 {
					temperature = <0x17318>;
					hysteresis = <0x3e8>;
					type = "passive";
					phandle = <0x0d>;
				};
			};

			cooling-maps {

				ddr-map0 {
					trip = <0x0d>;
					phandle = <0x12a>;
					cooling-device = <0x0e 0xffffffff 0xffffffff>;
				};
			};
		};

		thermal-cpu {
			polling-delay = <0x3e8>;
			polling-delay-passive = <0x3e8>;
			thermal-sensors = <0x01 0x02>;
			phandle = <0x123>;

			trips {

				cpu-crit {
					temperature = <0x1adb0>;
					hysteresis = <0x00>;
					type = "critical";
					phandle = <0x125>;
				};

				cpu-alert0 {
					temperature = <0x1adb0>;
					hysteresis = <0x1f4>;
					type = "passive";
					phandle = <0x124>;
				};

				cpu-alert1 {
					temperature = <0x17318>;
					hysteresis = <0x3e8>;
					type = "passive";
					phandle = <0x02>;
				};
			};

			cooling-maps {

				cpu-map1 {
					trip = <0x02>;
					phandle = <0x127>;
					cooling-device = <0x0b 0xffffffff 0xffffffff>;
				};

				cpu-map2 {
					trip = <0x02>;
					phandle = <0x128>;
					cooling-device = <0x0c 0xffffffff 0xffffffff>;
				};

				cpu-map0 {
					trip = <0x02>;
					phandle = <0x126>;
					cooling-device = <0x03 0xffffffff 0xffffffff 0x04 0xffffffff 0xffffffff 0x05 0xffffffff 0xffffffff 0x06 0xffffffff 0xffffffff 0x07 0xffffffff 0xffffffff 0x08 0xffffffff 0xffffffff 0x09 0xffffffff 0xffffffff 0x0a 0xffffffff 0xffffffff>;
				};
			};
		};
	};

	vdd08_gpu_reg@3 {
		regulator-max-microvolt = "\0\f5";
		pinctrl-names = "default";
		pinctrl-0 = <0x11e>;
		enable-gpio = <0x11f 0x05 0x00>;
		regulator-enable-ramp-delay = <0xbb8>;
		enable-active-high;
		regulator-min-microvolt = "\0\f5";
		regulator-name = "VCC_GPU";
		regulator-ramp-delay = <0x7d0>;
		startup-delay-us = <0xbb8>;
		compatible = "regulator-gpio";
		status = "okay";
		states = <0xc3500 0x00>;
		phandle = <0x5d>;
	};

	soc {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		compatible = "simple-bus";
		ranges = <0x00 0x00 0x00 0x40000000>;

		gpu2d_qos@20540000 {
			power-domains = <0x24 0x03>;
			ports-num = <0x01>;
			clock-names = "gpu_pclk\0gpu2d_clk";
			clocks-num = <0x02>;
			clocks = <0x12 0x4b 0x12 0x47>;
			ports-off = <0x08>;
			consumer-dev = <0x65>;
			compatible = "d-robotics,noc_qos";
			status = "okay";
			reg = <0x20540000 0x80>;
			phandle = <0x17a>;
		};

		efuse@20301000 {
			pinctrl-names = "default";
			#address-cells = <0x01>;
			pinctrl-0 = <0x1f>;
			clock-names = "pclk_efuse";
			clocks = <0x12 0x80>;
			#size-cells = <0x01>;
			compatible = "horizon,tef12fcll64x32hd18phrm-efuse";
			reg = <0x20301150 0x38>;
			phandle = <0x130>;

			adc-offset@24 {
				reg = <0x24 0x04>;
				phandle = <0xfe>;
			};

			adc-trimming@24 {
				reg = <0x24 0x04>;
				phandle = <0xff>;
			};
		};

		usb2_qos@20550300 {
			ports-num = <0x01>;
			clock-names = "axi_clk";
			clocks-num = <0x01>;
			clocks = <0x12 0x76>;
			ports-off = <0x08>;
			compatible = "d-robotics,noc_qos";
			status = "okay";
			reg = <0x20550300 0x80>;
			phandle = <0x1a1>;
		};

		tee_regmap_services {
			fid = <0xc200000b>;
			w_cmd = <0x01>;
			method = "smc";
			compatible = "hobot,j5-sci\0syscon-tee\0simple-bus";
			u_cmd = <0x02>;
			phandle = <0x20>;
			r_cmd = <0x00>;
		};

		bpu_iommu@3a010030 {
			power-domains = <0x24 0x04>;
			#iommu-cells = <0x00>;
			compatible = "d-robotics,lite_mmu";
			status = "okay";
			reg = <0x3a010030 0x14>;
			phandle = <0x67>;
		};

		cti@2d020000 {
			clock-names = "apb_pclk\0atclk";
			clocks = <0x12 0x18 0x12 0x19>;
			cpu = <0x03>;
			arm,cs-dev-assoc = <0x47>;
			compatible = "arm,coresight-cti-v8-arch\0arm,coresight-cti\0arm,primecell";
			status = "okay";
			reg = <0x2d020000 0x1000>;
			phandle = <0x15e>;
		};

		dsp_apb {
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			compatible = "simple-bus";
			ranges;
			reg = <0x32080000 0x100000>;

			dw_i2s1@320c0000 {
				mclk-fs = <0x40>;
				pinctrl-names = "default";
				pinctrl-0 = <0xc1>;
				clock-names = "sclk\0i2s_pclk\0i2s_mux_clk\0i2s_external\0i2s_mclk";
				resets = <0xb9 0x07>;
				dwc-master = <0x00>;
				clocks = <0x5b 0x1e 0x5b 0x20 0x5b 0x25 0x5a 0x5b 0x1f>;
				dma-names = "tx\0rx";
				channel = <0x02>;
				#sound-dai-cells = <0x00>;
