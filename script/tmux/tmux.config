# Use Ctrl-q as the tmux prefix.
unbind-key C-b
set-option -g prefix C-q
bind-key C-q send-prefix

# Advertise terminal features needed by Neovim inside tmux.
set -g default-terminal "tmux-256color"
set -g terminal-features "xterm*:clipboard:ccolour:cstyle:focus:title:RGB,tmux*:RGB:cstyle"

# Copy selected tmux text to the system clipboard.
set -g set-clipboard on
set -g mode-keys vi
bind-key -T copy-mode-vi C-S-c send -X copy-pipe-and-cancel "clip.exe"
bind-key -T copy-mode C-S-c send -X copy-pipe-and-cancel "clip.exe"
bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "clip.exe"

# Enable mouse support for pane selection, resizing, and scrolling.
set -g mouse on

# Split panes with prefix + | and prefix + -.
bind-key | split-window -h
bind-key - split-window -v

# Move between panes with Neovim-style Ctrl-h/j/k/l.
bind-key -n C-h select-pane -L
bind-key -n C-j select-pane -D
bind-key -n C-k select-pane -U
bind-key -n C-l select-pane -R
